{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SendMessageToSQS",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage"
      ],
      "Resource": "arn:aws:sqs:ca-central-1:951125265513:harita-testpulse-ingestion-queue"
    },
    {
      "Sid": "WriteToS3",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject"
      ],
      "Resource": "arn:aws:s3:::harita-testpulse-raw-2026/*"
    },
    {
      "Sid": "WriteCloudWatchLogs",
      "Effect": "Allow",
      "Action": [
        "logs:CreateLogGroup",
        "logs:CreateLogStream",
        "logs:PutLogEvents"
      ],
      "Resource": "arn:aws:logs:ca-central-1:951125265513:*"
    }
  ]
}