{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ReadFromSQS",
      "Effect": "Allow",
      "Action": [
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": "arn:aws:sqs:ca-central-1:951125265513:harita-testpulse-ingestion-queue"
    },
    {
      "Sid": "ReadFromS3",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::harita-testpulse-raw-2026/*"
    }
  ]
}